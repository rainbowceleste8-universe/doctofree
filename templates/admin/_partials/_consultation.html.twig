<div class="card p-4 m-3">
    <h4 class="mb-3">Consultation du {{ consultation.dateHeure| date('d/m/Y à H:i') }} par le Dr {{ consultation.rendezvous.medecin }}</h4>
    <div class="row">
        <div class="col-12 col-md-6">
            Anamnèse : 
        </div>
        <div class="col-12 col-md-6">
            {{ consultation.anamnese }} 
        </div>
        <div class="col-12 col-md-6">
            Diagnostic : 
        </div>
        <div class="col-12 col-md-6">
            {{ consultation.diagnostic }} 
        </div>
        <div class="col-12 col-md-6">
            Notes : 
        </div>
        <div class="col-12 col-md-6">
            {{ consultation.notes }} 
        </div>
    </div>
    {% if consultation.ordonnance is not null %}
        <div class="row">
            <div class="col-12 col-md-6">
                <h5 class="my-3">Ordonnance du {{ consultation.ordonnance.dateEmission| date('d/m/Y') }}</h5>
                <small>Valide jusqu'au {{ consultation.ordonnance.dateValidite| date('d/m/Y') }}</small>
                <br>
                {{ consultation.ordonnance.instructions }}
            </div>
            <div class="col-12 col-md-6">
                <h5 class="my-3">Prescriptions</h5>
                <ul>
                    {% for pres in consultation.ordonnance.prescriptions %}
                        <li>
                            {{ pres.medicament.nom }} ({{ pres.medicament.dosage }}) : {{ pres.posologie }}, {{ pres.frequence }} pendant {{ pres.dureeJours }} jours
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}
</div>