{% extends 'admin/base.html.twig' %}

{% block title %}Specialite index{% endblock %}

{% block admin_content %}
    <h1>Specialite index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Libelle</th>
                <th>Description</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for specialite in specialites %}
            <tr>
                <td>{{ specialite.id }}</td>
                <td>{{ specialite.libelle }}</td>
                <td>{{ specialite.description }}</td>
                <td>
                    <a href="{{ path('app_admin_specialite_show', {'id': specialite.id}) }}">show</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
