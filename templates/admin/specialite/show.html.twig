{% extends 'admin/base.html.twig' %}

{% block title %}Specialite{% endblock %}

{% block admin_content %}
    <h1>Specialite</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ specialite.id }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ specialite.libelle }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ specialite.description }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_specialite_index') }}">back to list</a>

{% endblock %}
