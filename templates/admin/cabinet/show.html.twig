{% extends 'admin/base.html.twig' %}

{% block title %}Cabinet{% endblock %}

{% block admin_content %}
    <h1>Cabinet</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cabinet.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ cabinet.nom }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ cabinet.adresse }}</td>
            </tr>
            <tr>
                <th>Telephone</th>
                <td>{{ cabinet.telephone }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_cabinet_index') }}">back to list</a>

{% endblock %}
