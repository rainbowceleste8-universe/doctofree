{% extends 'admin/base.html.twig' %}

{% block title %}Cabinet index{% endblock %}

{% block admin_content %}
    <h1>Cabinet index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Adresse</th>
                <th>Telephone</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for cabinet in cabinets %}
            <tr>
                <td>{{ cabinet.id }}</td>
                <td>{{ cabinet.nom }}</td>
                <td>{{ cabinet.adresse }}</td>
                <td>{{ cabinet.telephone }}</td>
                <td>
                    <a href="{{ path('app_admin_cabinet_show', {'id': cabinet.id}) }}">show</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
